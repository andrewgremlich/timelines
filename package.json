{
	"name": "timelines",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare",
		"deploy": "pnpm build && wrangler pages deploy .svelte-kit/cloudflare",
		"db:migrate:local": "wrangler d1 migrations apply timelines --local",
		"db:migrate:remote": "wrangler d1 migrations apply timelines --remote",
		"db:seed:admin:local": "node --experimental-strip-types scripts/seed-admin.ts > .seed-admin.sql && wrangler d1 execute timelines --local --file=.seed-admin.sql && rm .seed-admin.sql",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260418.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"wrangler": "^4.83.0"
	},
	"dependencies": {
		"@fontsource/merriweather": "^5.2.11",
		"@fontsource/merriweather-sans": "^5.2.7",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0"
	}
}
